---
import Layout from '../../layouts/Layout.astro';

const { username } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';

let profile: any = null;
let posts: any[] = [];
let claims: any = null;
let error: string | null = null;

async function safeFetch(url: string) {
  try {
    const r = await fetch(url);
    if (r.ok) return r.json();
  } catch (_) {}
  return null;
}

try {
  profile = await safeFetch(`${API_URL}/api/profiles/${username}`);
  if (!profile) error = 'Profile not found';
} catch (err) {
  error = 'Failed to connect to API';
}

if (profile) {
  const ethAddr = profile.ethereum_address;
  if (ethAddr) {
    claims = await safeFetch(`${API_URL}/api/contracts/claims/${ethAddr}`);
  }
}

const title = profile
  ? `${profile.display_name || profile.username} (@${username}) — SocialAi`
  : 'Profile Not Found — SocialAi';
const description = profile?.bio || `View ${username}'s profile on SocialAi`;

// JSON-LD structured data
const jsonLd = profile ? {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.display_name || profile.username,
  alternateName: `@${profile.username}`,
  description: profile.bio || '',
  image: profile.avatar_url || '',
  url: `${Astro.url.origin}/profile/${username}`,
} : null;
---

<Layout title={title}>
  <meta slot="head" name="description" content={description} />
  <meta slot="head" property="og:title" content={title} />
  <meta slot="head" property="og:description" content={description} />
  {profile?.avatar_url && <meta slot="head" property="og:image" content={profile.avatar_url} />}
  <meta slot="head" property="og:type" content="profile" />
  {jsonLd && <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <style>
    .profile-container { max-width: 860px; margin: 0 auto; }

    /* Header card */
    .profile-header {
      background: var(--glass-bg);
      border: var(--glass-border);
      border-radius: var(--radius-xl);
      padding: 2rem;
      backdrop-filter: var(--glass-blur);
      box-shadow: var(--shadow-glass);
      margin-bottom: 1.5rem;
    }
    .profile-top {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }
    .profile-avatar {
      width: 100px; height: 100px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-neon-violet), var(--color-neon-cyan));
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem; font-weight: 700; color: #fff;
      flex-shrink: 0;
      box-shadow: var(--glow-violet);
      overflow: hidden;
    }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
    .profile-info { flex: 1; min-width: 200px; }
    .profile-name {
      font-size: 1.75rem; font-weight: 800; margin-bottom: 0.25rem;
      color: var(--color-text-primary);
    }
    .profile-handle {
      font-size: 1rem; color: var(--color-neon-cyan); font-weight: 600; margin-bottom: 0.75rem;
    }
    .profile-bio { color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .profile-badges {
      display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;
    }
    .badge {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.25rem 0.75rem; border-radius: var(--radius-full);
      font-size: 0.75rem; font-weight: 600;
    }
    .badge-verified {
      background: rgba(0,255,136,0.12); color: var(--color-neon-lime);
      border: 1px solid rgba(0,255,136,0.25);
    }
    .badge-claimed {
      background: rgba(139,92,246,0.12); color: var(--color-neon-violet);
      border: 1px solid rgba(139,92,246,0.25);
    }
    .badge-chain {
      background: rgba(0,255,245,0.08); color: var(--color-neon-cyan);
      border: 1px solid rgba(0,255,245,0.2);
    }
    .profile-stats {
      display: flex; gap: 2rem; padding-top: 1rem;
      border-top: 1px solid var(--color-border);
      flex-wrap: wrap;
    }
    .stat { display: flex; flex-direction: column; }
    .stat-val { font-size: 1.5rem; font-weight: 700; color: var(--color-neon-violet); }
    .stat-lbl { font-size: 0.75rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

    /* On-chain section */
    .onchain-card {
      background: var(--glass-bg); border: var(--glass-border);
      border-radius: var(--radius-lg); padding: 1.25rem 1.5rem;
      backdrop-filter: var(--glass-blur); margin-bottom: 1.5rem;
    }
    .section-title {
      font-size: 0.875rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--color-neon-cyan); margin-bottom: 0.75rem;
    }
    .claim-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.4rem 0; border-bottom: 1px solid var(--color-border);
      font-size: 0.85rem;
    }
    .claim-row:last-child { border-bottom: none; }
    .claim-type { color: var(--color-text-muted); }
    .claim-status { color: var(--color-neon-lime); font-weight: 600; }

    /* Error / not found */
    .error-card {
      background: var(--glass-bg); border: var(--glass-border);
      border-radius: var(--radius-xl); padding: 3rem; text-align: center;
      backdrop-filter: var(--glass-blur);
    }
    .error-icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .error-title { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.75rem; color: var(--color-text-primary); }
    .error-msg { color: var(--color-text-muted); margin-bottom: 1.5rem; }
    .btn-back {
      display: inline-block; padding: 0.6rem 1.5rem;
      background: rgba(139,92,246,0.2); color: var(--color-neon-violet);
      border: 1px solid rgba(139,92,246,0.4); border-radius: var(--radius-md);
      text-decoration: none; font-weight: 600; font-size: 0.9rem;
      transition: background var(--transition-fast);
    }
    .btn-back:hover { background: rgba(139,92,246,0.35); }

    @media (max-width: 640px) {
      .profile-top { flex-direction: column; align-items: center; text-align: center; }
      .profile-badges { justify-content: center; }
      .profile-stats { justify-content: center; }
    }
  </style>

  <div class="profile-container">
    {error ? (
      <div class="error-card">
        <div class="error-icon">🔍</div>
        <h1 class="error-title">Profile Not Found</h1>
        <p class="error-msg">The profile @{username} doesn't exist or hasn't been claimed yet.</p>
        <a href="/profiles" class="btn-back">Browse Profiles</a>
      </div>
    ) : profile ? (
      <>
        <div class="profile-header">
          <div class="profile-top">
            <div class="profile-avatar">
              {profile.avatar_url
                ? <img src={profile.avatar_url} alt={profile.display_name || profile.username} />
                : (profile.display_name?.[0] || profile.username[0]).toUpperCase()
              }
            </div>
            <div class="profile-info">
              <h1 class="profile-name">{profile.display_name || profile.username}</h1>
              <div class="profile-handle">@{profile.username}</div>
              {profile.bio && <p class="profile-bio">{profile.bio}</p>}

              <div class="profile-badges">
                {profile.verified && <span class="badge badge-verified">✅ Verified</span>}
                {profile.claimed && <span class="badge badge-claimed">🪪 Claimed</span>}
                {profile.twitter_handle && <span class="badge badge-chain">🐦 @{profile.twitter_handle}</span>}
                {profile.website_url && <span class="badge badge-chain">🔗 Website</span>}
              </div>

              <div class="profile-stats">
                <div class="stat">
                  <span class="stat-val">0</span>
                  <span class="stat-lbl">Followers</span>
                </div>
                <div class="stat">
                  <span class="stat-val">0</span>
                  <span class="stat-lbl">Following</span>
                </div>
                <div class="stat">
                  <span class="stat-val">0</span>
                  <span class="stat-lbl">Posts</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        {claims?.db_claims?.length > 0 && (
          <div class="onchain-card">
            <div class="section-title">🔗 On-Chain Identity Claims</div>
            {claims.db_claims.map((c: any) => (
              <div class="claim-row">
                <span class="claim-type">{c.claim_type}</span>
                <span class="claim-status">{c.verified ? '✅ Verified' : '⏳ Pending'}</span>
              </div>
            ))}
          </div>
        )}
      </>
    ) : null}
  </div>
</Layout>
